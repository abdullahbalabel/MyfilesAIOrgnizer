{
  "name": "myfiles-ai-organizer",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered file organizer for your desktop",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 -t 30000 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "electron:portable": "vite build && electron-builder --win portable",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "lucide-react": "^0.511.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.myfiles.aiorganizer",
    "productName": "MyFiles AI Organizer",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/.cache/**/*",
      "!node_modules/.bin/**/*",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.map"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
